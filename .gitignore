# ============================================================
# .gitignore — Files Git Should Never Track
# ============================================================
# Lines starting with # are comments.
# Each line below tells Git: "ignore this file/folder".

# Never upload your secret environment variables
.env

# Never upload the node_modules folder — it's huge (often 100MB+)
# and anyone can recreate it by running: npm install
node_modules/

# Mac system file (junk file macOS creates automatically)
.DS_Store

# Windows system files
Thumbs.db